# ===== MOCHA BACKEND ENV =====
NODE_ENV=production
PORT=5000

# Frontend URL (Vercel URL after deploy)
FRONTEND_URL=https://mocha-app.vercel.app

# Backend URL (Railway URL after deploy)
SERVER_URL=https://mocha-backend.railway.app

# Session
SESSION_SECRET=your-super-secret-key-change-this-now

# ===== GOOGLE OAUTH =====
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===== AI =====
ANTHROPIC_API_KEY=your-anthropic-api-key

# ===== SPORTS APIs =====
# Get free key from: https://dashboard.api-football.com/register
API_FOOTBALL_KEY=your-api-football-key

# Get free key from: https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=your-football-data-key

# TheSportsDB - free tier uses key "3"
SPORTSDB_KEY=3

# RapidAPI key for FlashScore
RAPIDAPI_KEY=your-rapidapi-key

# Optional
SPORTRADAR_KEY=your-sportradar-key
LIVESCORE_KEY=your-livescore-key
LIVESCORE_SECRET=your-livescore-secret
